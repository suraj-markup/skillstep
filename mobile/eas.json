{
  "cli": {
    "appVersionSource": "local",
    "version": ">= 16.0.0"
  },
  "build": {
    "preview": {
      "channel": "preview",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://skillstep-beta.vercel.app/api"
      }
    },
    "production": {
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://skillstep-beta.vercel.app/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
