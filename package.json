{
  "name": "whittle",
  "private": true,
  "version": "0.1.0",
  "description": "Get better at anything — six techniques at a time.",
  "workspaces": [
    "mobile",
    "server",
    "shared"
  ],
  "scripts": {
    "dev:mobile": "npm run start -w @whittle/mobile",
    "dev:server": "npm run dev -w @whittle/server",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "biome check .",
    "format": "biome check --write .",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
